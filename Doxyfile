# Doxyfile for the srmd / sra project
# Generated for Doxygen 1.9.x
# Run: doxygen Doxyfile   (from the repository root)
# Output: docs/html/index.html

#---------------------------------------------------------------------------
# Project identity
#---------------------------------------------------------------------------
PROJECT_NAME           = "rtsrv — Switch Route Manager"
PROJECT_NUMBER         = 1.0.0
PROJECT_BRIEF          = "srmd daemon + sra CLI client for network route management over gRPC"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = \
    client/include       \
    client/src           \
    common/include       \
    common/src           \
    server/include       \
    server/src           \
    unix_domain/lib      \
    unix_domain/ud_server.cpp \
    test

RECURSIVE              = YES
# Process headers and plain-C headers only.
# Implementations use @copybrief to inherit from headers; including both would
# produce circular-reference warnings in Doxygen.  The full source is browsable
# via the Git repository; the header API is the authoritative documentation.
FILE_PATTERNS          = *.hpp *.h
EXCLUDE_PATTERNS       = */server-build/* */proto_gen/* *.pb.h

#---------------------------------------------------------------------------
# Extraction & processing
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = YES
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 4

#---------------------------------------------------------------------------
# Build options
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = \
    client/include       \
    common/include       \
    server/include       \
    unix_domain/lib

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_LOGFILE           = docs/doxygen_warnings.log

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Source browser
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
USE_HTAGS              = NO
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# Graphs (requires graphviz / dot)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

#---------------------------------------------------------------------------
# Index / search
#---------------------------------------------------------------------------
ALPHABETICAL_INDEX     = YES
IGNORE_PREFIX          =
SEARCHENGINE           = YES
